# API key del proveedor LLM (OpenRouter, Together, etc.)
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL del proveedor (ej: OpenRouter, Together AI, etc.)
OPENAI_BASE_URL=https://api.openrouter.ai/v1

# Modelo a usar (formato provider/modelo, ej: opencode/deepseek-v4-flash-free)
MODEL_NAME=opencode/deepseek-v4-flash-free

# Puerto del servidor web
FLASK_PORT=5000

# Credenciales del panel de administración
ADMIN_USER=adminanon
ADMIN_PASS=cambiar-esta-clave

# Secret key para sesiones Flask (usar un string aleatorio seguro)
FLASK_SECRET_KEY=cambiar-por-string-aleatorio

# Cookie de sesión solo por HTTPS (1 en producción con TLS)
SESSION_COOKIE_SECURE=0

# Backend de sesión: redis (recomendado) o cookie
SESSION_BACKEND=redis

# URL de Redis compartido (single o HA)
REDIS_URL=redis://redis:6379/0

# Puerto publicado de Redis (si necesitás acceso desde otros compose/hosts)
REDIS_PORT=6379

# Key donde se persiste config compartida (prompt/patrones/modelo)
REDIS_CONFIG_KEY=anonimizador:config

# Umbral de requests concurrentes para /ready (HAProxy)
READY_MAX_INFLIGHT=2

# Retención de uploads en segundos (PII original). Default: 24h
UPLOAD_TTL_SECONDS=86400

# Rate limit login admin (ventana y máximo intentos)
LOGIN_WINDOW_SECONDS=300
LOGIN_MAX_ATTEMPTS=5

# Concurrencia para inferencia local (ej: Ollama)
# Solo aplica cuando model_url apunta a un proveedor local (localhost/ollama/etc.)
LOCAL_INFERENCE_MAX=3
LOCAL_INFERENCE_WAIT_SECONDS=90
LOCAL_INFERENCE_POLL_SECONDS=1.5
LOCAL_INFERENCE_SLOT_TTL_SECONDS=180
